# ============================================================
# Medical Device Monitoring System — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to Git.

# --- Supabase (PostgreSQL Connection String — Transaction Mode) ---
# IMPORTANT: Two parameters are REQUIRED for Supabase Transaction Pooler (port 6543) + Npgsql/EF Core:
#   Maximum Auto Prepare=0   → disables EF Core auto-prepared statements (not supported by PgBouncer)
#   No Reset On Close=true   → prevents Npgsql sending cleanup commands between pooled connections
# Remove both only if you switch to Session Pooler (port 5432).
SUPABASE_CONN_STRING="Host=aws-0-ap-southeast-1.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.YOUR_PROJECT_REF;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;Disable Prepared Statements=true;No Reset On Close=true"

# --- .NET Backend ---
ASPNETCORE_ENVIRONMENT=Development
# Port the backend listens on (used in docker-compose)
BACKEND_PORT=5000

# --- JWT Auth (if implemented) ---
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_KEY
JWT_ISSUER=MedicalDeviceMonitor
JWT_AUDIENCE=MedicalDeviceMonitorClient
JWT_EXPIRY_MINUTES=60

# --- Device Simulator ---
# Base URL of the running .NET backend (used by device_simulator.py)
BACKEND_API_URL=http://localhost:5000

# --- Grafana ---
# Admin credentials for the Grafana dashboard (http://localhost:3001)
GRAFANA_USER=admin
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- Loki ---
LOKI_URL=http://localhost:3100/loki/api/v1/push
