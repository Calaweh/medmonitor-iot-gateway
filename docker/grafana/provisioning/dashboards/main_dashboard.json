{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Real-time Clinical Logs ($device_code)",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{device=\"$device_code\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "title": "Ingestion Rate by Device",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(rate(scrape_duration_seconds[1m])) by (device)",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "device_code",
        "label": "Select Bed",
        "type": "custom",
        "query": "ICU-BED-01, ICU-BED-02, ICU-BED-03",
        "multi": false,
        "includeAll": false,
        "current": { "text": "ICU-BED-01", "value": "ICU-BED-01" }
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "title": "Hospital Command Center",
  "uid": "hospital-vitals",
  "version": 1
}